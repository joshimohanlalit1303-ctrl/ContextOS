{
  "manifest_version": 3,
  "name": "ContextOS",
  "version": "1.0.0",
  "description": "Your AI User Context Layer",
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "identity",
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["src/content/tracker.ts"]
    }
  ]
}
