{
  "manifest_version": 3,
  "name": "Libro Memory Clipper",
  "version": "1.0.0",
  "description": "Highlight text anywhere on the web and instantly save it to your AI brain using the Libro SDK.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
