{
  "name": "libro-mcp-server",
  "version": "1.0.0",
  "description": "An MCP server for bridging AI agents into Libro's Hive Memory.",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "libro-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "tsup src/index.ts --format esm,cjs --watch --onSuccess 'node dist/index.js'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "libro-sdk": "file:../libro-sdk",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
